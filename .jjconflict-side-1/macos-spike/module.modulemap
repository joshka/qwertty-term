// Clang module map so `import CGhosttyRs` in Swift pulls in the cbindgen header.
// This is the minimal ceremony to consume a C ABI from Swift without an Xcode
// project (the spike is a single swiftc invocation; see build.sh).
module CGhosttyRs {
  header "../crates/ghostty-ffi/include/ghostty_rs.h"
  export *
}
