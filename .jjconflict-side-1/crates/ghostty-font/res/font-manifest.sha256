# Manifest of vendored default-font assets, copied VERBATIM (byte-for-byte)
# from the exact upstream Ghostty release assets referenced by
# `src/font/embedded.zig` at pinned commit `2da015cd6`
# (`2da015cd6ac06cedc89e09756e895d2c1715205d`):
#
#   - JetBrainsMono-Variable.ttf        <- fonts/variable/JetBrainsMono[wght].ttf
#                                          from the `jetbrains_mono_variable`
#                                          build.zig.zon fetch (JetBrains Mono
#                                          release, font-tools variable build).
#   - JetBrainsMono-Italic-Variable.ttf <- fonts/variable/JetBrainsMono-Italic[wght].ttf
#                                          from the `jetbrains_mono_variable_italic`
#                                          fetch.
#   - SymbolsNerdFontMono-Regular.ttf   <- SymbolsNerdFontMono-Regular.ttf from
#                                          the `nerd_fonts_symbols_only` fetch
#                                          (Nerd Fonts release asset).
#   - OFL.txt                            <- the JetBrains Mono variable fetch's
#                                          own OFL.txt (JetBrains Mono Project
#                                          Authors copyright header).
#   - NerdFonts-LICENSE.txt              <- the nerd_fonts_symbols_only fetch's
#                                          LICENSE (MIT, Nerd Fonts patcher).
#   - NotoEmoji-Regular.ttf              <- upstream `res/NotoEmoji-Regular.ttf`
#                                          (embedded.emoji_text), unchanged from
#                                          the prior vendoring in this crate.
#
# Regenerate after a deliberate re-vendor (upstream pin bump) with:
#   cd crates/ghostty-font/res
#   for f in JetBrainsMono-Variable.ttf JetBrainsMono-Italic-Variable.ttf \
#            SymbolsNerdFontMono-Regular.ttf OFL.txt NerdFonts-LICENSE.txt \
#            NotoEmoji-Regular.ttf; do
#     hash=$(shasum -a 256 "$f" | awk '{print $1}')
#     size=$(wc -c < "$f" | tr -d ' ')
#     echo "$hash  $size  $f"
#   done
#
# `tests/font_manifest.rs` fails loudly if the vendored tree drifts from this
# manifest (hand-edit, partial re-vendor, or an upstream pin bump that wasn't
# accompanied by a manifest regeneration + review).
#
# format: <sha256>  <size-bytes>  <filename under res/>
662a196d58f1183bf2d77428b6d5283fe3f45161ab021bea4036bc98e5cac016  303144  JetBrainsMono-Variable.ttf
f115aaa12113718c02ce72864fe6823b87241bc23d3e44cf1220155f861063f2  308888  JetBrainsMono-Italic-Variable.ttf
f0f624d9b474bea1662cf7e862d44aebe1ae1f6c7f9cb7a0ca5d0e5ac9561c60  2507556  SymbolsNerdFontMono-Regular.ttf
30f0c136e3c88e422d0791acd97238870f9054a9729bc34cf2ff0d4ed8cac4ad  4399  OFL.txt
84a7a98c82140fb12c37fe42b93805baa16024cb3e5acc599b7ffe612c55d847  1082  NerdFonts-LICENSE.txt
84a38f2f02374efb72cac2b7eb5589102e06fffc33f7b531ed708f4a08236c91  868608  NotoEmoji-Regular.ttf
