# cargo-fuzz build artifacts and crash repros: never committed.
/target
/artifacts
/coverage

# The corpus dir is where libFuzzer writes newly-discovered inputs during a
# campaign (thousands of hash-named files). Ignore all of it, then re-include
# only the curated, human-named seed inputs we ship as the starting corpus.
# Keeping generated inputs out of version control avoids churn while still
# giving a campaign a strong seed set (alt-screen + resize interleavings).
/corpus/*/*
!/corpus/resize/alt_enterexit_churn
!/corpus/resize/cup_corners_after_grow
!/corpus/resize/decstbm_scroll_resize
!/corpus/resize/field_crash_resize
!/corpus/resize/origin_margins_resize
!/corpus/resize/rapid_resize_typing
!/corpus/resize/wide_char_right_edge_resize
